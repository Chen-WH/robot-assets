<mujoco model="ur10_reorientation_scene">
  <include file="../ur10/ur10.xml"/>

  <statistic center="0.4 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <texture name="graycube" type="cube"
             fileup="./textures/grayup.png"
             fileback="./textures/grayback.png"
             filedown="./textures/graydown.png"
             filefront="./textures/grayfront.png"
             fileleft="./textures/grayleft.png"
             fileright="./textures/grayright.png"/>
    <material name="graycube" texture="graycube"/>
    <material name="red" rgba="1 0 0 1"/>
    <material name="green" rgba="0 1 0 1"/>
    <material name="blue" rgba="0 0 1 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="ee_target" mocap="true" pos="0.6 0.0 0.35" quat="1 0 0 0">
      <geom name="target_cube" type="box" size="0.03 0.03 0.03" material="graycube" contype="0" conaffinity="0"/>
      <geom name="target_axis_x" type="box" size="0.03 0.002 0.002" pos="0.03 0 0" material="red" contype="0" conaffinity="0"/>
      <geom name="target_axis_y" type="box" size="0.003 0.03 0.002" pos="0 0.03 0" material="green" contype="0" conaffinity="0"/>
      <geom name="target_axis_z" type="box" size="0.003 0.002 0.03" pos="0 0 0.03" material="blue" contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
